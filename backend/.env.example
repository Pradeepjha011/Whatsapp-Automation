NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
DATABASE_URL=./db/whatsapp_inbox.sqlite
SERVE_FRONTEND=false
ENABLE_TESTING_ROUTES=true
WHATSAPP_TOKEN=your_meta_access_token
PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id
WHATSAPP_API_VERSION=v19.0
WHATSAPP_VERIFY_TOKEN=your_verify_token
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token
ZOHO_ACCOUNTS_URL=https://accounts.zoho.in
ZOHO_API_BASE=https://www.zohoapis.in
ZOHO_MODULE=Leads
INBOX_TRIGGER_TAG=WA
INBOX_CRM_SYNC_INTERVAL_MS=30000
ENABLE_CRM_SYNC=true
INBOX_DEFAULT_TEMPLATE_NAME=hello_world
INBOX_DEFAULT_TEMPLATE_LANG=en_US
